# Database (PostgreSQL — es. Supabase)
# Locale: diretta db.<ref>.supabase.co:5432 va bene.
#
# Render (IPv4): preferisci Session pool — Connect → Session pooler:
#   postgresql://postgres.your-project-ref:PWD@aws-0-eu-west-1.pooler.supabase.com:5432/postgres?sslmode=require
# Se db.*:6543 è raggiungibile: Transaction pool + ?pgbouncer=true&sslmode=require (utente solo "postgres").
#
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.your-project-ref.supabase.co:5432/postgres

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production

# Server
PORT=3001
NODE_ENV=production

# Frontend URL (per CORS). Più origini separate da virgola, es. produzione + preview Vercel:
# FRONTEND_URL=https://casa-mia.vercel.app,https://casa-mia-git-main-xxx.vercel.app
FRONTEND_URL=http://localhost:3000

# WebSocket
WS_PORT=3002

# Opzionale: nascondi log 🗄️ DB target all’avvio (host/porta/utente, senza password)
# LOG_DATABASE_TARGET=0
