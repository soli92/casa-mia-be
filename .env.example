# Database (PostgreSQL — es. Supabase)
# Locale: diretta db.<ref>.supabase.co:5432 va bene.
#
# Render (IPv4): dalla dashboard → Connect → Transaction pooler = db.<ref>.supabase.co:6543 + utente "postgres" + ?pgbouncer=true
#   DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.your-project-ref.supabase.co:6543/postgres?pgbouncer=true
# Alternativa Session pooler: aws-0-REGION.pooler.supabase.com:5432 + utente postgres.<ref> (non mischiare host/utente delle due modalità).
#
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.your-project-ref.supabase.co:5432/postgres

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production

# Server
PORT=3001
NODE_ENV=production

# Frontend URL (per CORS). Più origini separate da virgola, es. produzione + preview Vercel:
# FRONTEND_URL=https://casa-mia.vercel.app,https://casa-mia-git-main-xxx.vercel.app
FRONTEND_URL=http://localhost:3000

# WebSocket
WS_PORT=3002
