# Database (Supabase PostgreSQL)
# Ottieni la tua connection string da: Supabase Dashboard → Project Settings → Database → Connection string
# Formato: postgresql://postgres:[PASSWORD]@[PROJECT_REF].supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres.your-project-ref.supabase.co:5432/postgres

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production

# Server
PORT=3001
NODE_ENV=production

# Frontend URL (per CORS). Più origini separate da virgola, es. produzione + preview Vercel:
# FRONTEND_URL=https://casa-mia.vercel.app,https://casa-mia-git-main-xxx.vercel.app
FRONTEND_URL=http://localhost:3000

# WebSocket
WS_PORT=3002
