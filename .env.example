# Database (PostgreSQL — es. Supabase)
# Locale: URI diretta (porta 5432) va bene.
# Render / altri host solo IPv4: usa "Transaction pool" (porta 6543, host aws-0-*.pooler.supabase.com)
# e aggiungi ?pgbouncer=true (Prisma). Copia da Dashboard → Database → Connection string.
#
# Diretta (dev):
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.your-project-ref.supabase.co:5432/postgres
# Produzione pooler + Prisma:
# DATABASE_URL=postgresql://postgres.your-project-ref:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.your-project-ref.supabase.co:5432/postgres

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production

# Server
PORT=3001
NODE_ENV=production

# Frontend URL (per CORS). Più origini separate da virgola, es. produzione + preview Vercel:
# FRONTEND_URL=https://casa-mia.vercel.app,https://casa-mia-git-main-xxx.vercel.app
FRONTEND_URL=http://localhost:3000

# WebSocket
WS_PORT=3002
